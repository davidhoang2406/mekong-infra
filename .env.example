# MinIO credentials (must match MINIO_ROOT_USER/PASSWORD in docker-compose.yml)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ENDPOINT=http://localhost:9000

# Bucket names
MINIO_BUCKET=market-data
MINIO_ANALYSIS_BUCKET=market-analysis

# Sibling-repo paths (defaults assume repos are cloned next to mekong-infra)
# Override if your repos are in different locations:
# MEKONG_JOBS_DIR=/absolute/path/to/mekong-jobs
# MEKONG_NOTEBOOKS_DIR=/absolute/path/to/mekong-notebooks
